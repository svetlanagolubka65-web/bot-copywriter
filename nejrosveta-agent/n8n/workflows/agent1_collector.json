    "Merge All Sources": { "main": [[{ "node": "Фильтр 24ч", "type": "main", "index": 0 }]] },
    "Фильтр 24ч": { "main": [[{ "node": "Есть статьи?", "type": "main", "index": 0 }]] },
    "Есть статьи?": { "main": [[{ "node": "TG: нет новостей", "type": "main", "index": 0 }], [{ "node": "Groq: выбрать топ-3", "type": "main", "index": 0 }]] },
